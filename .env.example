# Environment Variables for QueueStorm Investigator API
# Rename this file to .env and fill in the values for local development.
# DO NOT COMMIT THE ACTUAL .env FILE TO VERSION CONTROL!

# LLM Configuration
# Valid providers: gemini, openai, anthropic
LLM_PROVIDER=gemini
LLM_API_KEY=your_temporary_api_key_here
LLM_MODEL=gemini-2.0-flash

# Server Configuration
PORT=8000
LLM_TIMEOUT=25
